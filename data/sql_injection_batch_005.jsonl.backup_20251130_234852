ns\nfunc (h *SecureErrorHandler) isPotentialAttack(err error) bool {\n\terrMsg := err.Error()\n\n\t// Patterns that indicate injection attempts\n\tattackPatterns := []string{\n\t\t\"invalid input syntax\",\n\t\t\"syntax error at or near\",\n\t\t\"unterminated quoted string\",\n\t\t\"column .* does not exist\",\n\t\t\"permission denied for table\",\n\t\t\"CAST.*AS.*INT\", // Error-based injection\n\t}\n\n\tfor _, pattern := range attackPatterns {\n\t\tif containsPattern(errMsg, pattern) {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\nfunc containsPattern(s, pattern string) bool {\n\t// Simplified - use regexp in production\n\treturn len(s) > 0 && len(pattern) > 0\n}\n\nfunc (h *SecureErrorHandler) captureStackTrace() string {\n\tbuf := make([]byte, 4096)\n\tn := runtime.Stack(buf, false)\n\treturn string(buf[:n])\n}\n\n// logInternalError logs full error details (never exposed to users)\nfunc (h *SecureErrorHandler) logInternalError(dbErr *DBError) {\n\tlogEntry := map[string]interface{}{\n\t\t\"timestamp\":    dbErr.Timestamp.Format(time.RFC3339),\n\t\t\"request_id\":   dbErr.RequestID,\n\t\t\"operation\":    dbErr.Operation,\n\t\t\"severity\":     dbErr.Severity,\n\t\t\"internal_err\": dbErr.InternalErr.Error(),\n\t\t\"context\":      dbErr.Context,\n\t}\n\n\tif dbErr.Severity == SeverityCritical || dbErr.Severity == SeverityHigh {\n\t\tlogEntry[\"stack_trace\"] = dbErr.StackTrace\n\t}\n\n\tlogJSON, _ := json.Marshal(logEntry)\n\th.logger.Printf(\"DB_ERROR: %s\", string(logJSON))\n}\n\n// WriteErrorResponse sends sanitized error to client\nfunc (h *SecureErrorHandler) WriteErrorResponse(w http.ResponseWriter, dbErr *DBError) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(dbErr.HTTPStatus)\n\n\tresponse := map[string]interface{}{\n\t\t\"error\":      dbErr.UserMessage,\n\t\t\"request_id\": dbErr.RequestID,\n\t}\n\n\t// In dev mode, include more details\n\tif h.enableDev {\n\t\tresponse[\"internal_error\"] = dbErr.InternalErr.Error()\n\t\tresponse[\"stack_trace\"] = dbErr.StackTrace\n\t}\n\n\tjson.NewEncoder(w).Encode(response)\n}\n\n// Simple in-memory error monitor (use Redis/metrics system in production)\ntype InMemoryErrorMonitor struct {\n\terrorCounts map[string]int\n\tthreshold   int\n}\n\nfunc NewInMemoryErrorMonitor(threshold int) *InMemoryErrorMonitor {\n\treturn &InMemoryErrorMonitor{\n\t\terrorCounts: make(map[string]int),\n\t\tthreshold:   threshold,\n\t}\n}\n\nfunc (m *InMemoryErrorMonitor) TrackError(err *DBError) {\n\tkey := fmt.Sprintf(\"%s_%s\", err.Operation, err.Severity)\n\tm.errorCounts[key]++\n}\n\nfunc (m *InMemoryErrorMonitor) CheckThreshold(operation string) bool {\n\tcount := m.errorCounts[operation]\n\treturn count > m.threshold\n}\n\n// Example usage in microservice\ntype UserService struct {\n\tdb           *sql.DB\n\terrorHandler *SecureErrorHandler\n}\n\nfunc (s *UserService) GetUser(w http.ResponseWriter, r *http.Request) {\n\trequestID := r.Header.Get(\"X-Request-ID\")\n\tif requestID == \"\" {\n\t\trequestID = fmt.Sprintf(\"req_%d\", time.Now().UnixNano())\n\t}\n\n\tuserID := r.URL.Query().Get(\"id\")\n\n\t// Input validation\n\tif userID == \"\" {\n\t\thttp.Error(w, \"User ID required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Secure parameterized query\n\tquery := \"SELECT id, username, email FROM users WHERE id = $1\"\n\n\tvar id int\n\tvar username, email string\n\n\terr := s.db.QueryRow(query, userID).Scan(&id, &username, &email)\n\tif err != nil {\n\t\t// Handle error securely\n\t\tdbErr := s.errorHandler.HandleQueryError(\n\t\t\trequestID,\n\t\t\t\"GetUser\",\n\t\t\terr,\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"user_id\": userID,\n\t\t\t\t\"query\":   query,\n\t\t\t},\n\t\t)\n\n\t\ts.errorHandler.WriteErrorResponse(w, dbErr)\n\t\treturn\n\t}\n\n\t// Success\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]interface{}{\n\t\t\"id\":       id,\n\t\t\"username\": username,\n\t\t\"email\":    email,\n\t})\n}\n```\n\n**Deployment Best Practices:**\n\n1. **Environment-based verbosity**:\n```go\nisDev := os.Getenv(\"ENVIRONMENT\") == \"development\"\nerrorHandler := NewSecureErrorHandler(logger, monitor, isDev)\n```\n\n2. **Centralized logging integration**:\n```go\n// Send to Datadog, CloudWatch, Splunk, etc.\nlogger := log.New(cloudwatchWriter, \"\", 0)\n```\n\n3. **Alerting on suspicious patterns**:\n```go\nif isPotentialAttack(err) {\n\t// Send to SIEM\n\t// Increment security metrics\n\t// Potentially block IP/user\n}\n```\n\n4. **Error rate monitoring**:\n```go\n// Use Prometheus, StatsD, etc.\nerrorRate.WithLabelValues(operation, severity).Inc()\n```\n\n**Deployment Checklist:**\n\n✅ Replace all direct error responses with SecureErrorHandler\n✅ Set up centralized error logging (CloudWatch, Datadog, etc.)\n✅ Configure error rate monitoring and alerting\n✅ Enable dev mode only in development environments\n✅ Test with SQL injection payloads to verify error sanitization\n✅ Review logs to ensure no sensitive data in user-facing errors\n✅ Set up automated alerts for CRITICAL severity errors\n\nThis framework ensures SQL errors are handled securely across all microservices."}], "context": {"real_world_incident": "2024 Error-based SQL injection in Go microservices", "impact": "Database schema and data extracted via error messages", "attack_vector": "Verbose error messages exposing SQL structure", "cve": null, "year": 2024}, "validation": {"syntax_check": "not_tested", "security_review": "not_reviewed", "code_execution": "not_tested", "encoding_check": "not_tested", "duplication_check": "not_tested", "reviewed_by": "automated-generator", "review_date": "2025-11-30", "issues": []}}
